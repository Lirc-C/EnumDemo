<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.niit.mapper.StudentMapper">
    <resultMap id="studentResult" type="com.niit.model.Student">
        <id property="roll_no" column="roll_no"/>
        <result property="name" column="name"/>
        <result property="address" column="address"/>
        <result property="dob" column="dob"/>
        <result property="grade" column="grade"/>
        <result property="gender" column="gender"/>
    </resultMap>
    <insert id="insertStudent">
        INSERT INTO Student(name, address, dob, grade, gender)
        values (#{name}, #{address}, #{dob}, #{grade}, #{gender})
    </insert>
    <select id="getStudentByRollNumber" resultMap="studentResult"
            parameterType="com.niit.model.Student">
        Select roll_no, name, address, dob, grade, gender
        from Student where roll_no=#{roll_no}
    </select>
</mapper>